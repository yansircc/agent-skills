{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effect-ecosystem-skill.local/signals.schema.json",
  "schemaVersion": 1,
  "signals": [
    {
      "kind": "cloudflare-runtime-facts",
      "requiredTopLevel": [],
      "skill_ref": "references/runtime-boundaries.md §Cloudflare Facet",
      "agent_action": "Use these facts only as runtime substrate; decide support with validUnder proof, not scanner inference.",
      "factsSchemaRef": "runtime-facts.schema.json"
    },
    {
      "kind": "http-api-boundary-file",
      "requiredTopLevel": ["file"],
      "skill_ref": "references/platform-http.md §4. HttpApi — 声明式 HTTP 服务端",
      "agent_action": "Read the file and decide whether boundary DTOs/errors require effect/Schema.",
      "factsSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["containsHttpApiToken", "importsSchema"],
        "properties": {
          "containsHttpApiToken": { "type": "boolean" },
          "importsSchema": { "type": "boolean" }
        }
      }
    },
    {
      "kind": "rpc-boundary-file",
      "requiredTopLevel": ["file"],
      "skill_ref": "references/sql-and-rpc.md §第二部分：@effect/rpc",
      "agent_action": "Read the file and decide whether requests, responses, and errors are schema-backed.",
      "factsSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["containsRpcToken", "importsSchema"],
        "properties": {
          "containsRpcToken": { "type": "boolean" },
          "importsSchema": { "type": "boolean" }
        }
      }
    },
    {
      "kind": "library-exported-effect-file",
      "requiredTopLevel": ["package", "file"],
      "skill_ref": "references/observability.md §1. Span / Tracing",
      "agent_action": "Read exported Effects and decide which public boundaries need spans.",
      "factsSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["hasExports", "containsEffectType", "containsWithSpan"],
        "properties": {
          "hasExports": { "type": "boolean" },
          "containsEffectType": { "type": "boolean" },
          "containsWithSpan": { "type": "boolean" }
        }
      }
    },
    {
      "kind": "ai-runtime-facts",
      "requiredTopLevel": ["package"],
      "skill_ref": "references/effect-ai.md §Provider ownership",
      "agent_action": "Decide whether @effect/ai owns the loop and whether provider packages or declared transports are terminal adapters only.",
      "factsSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["hasEffectAiDependency", "effectAiProviderPackages", "declaredProviderTransports", "directProviderSdkDependencies"],
        "properties": {
          "hasEffectAiDependency": { "type": "boolean" },
          "effectAiProviderPackages": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "declaredProviderTransports": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "owner"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "owner": { "type": "string", "minLength": 1 }
              }
            }
          },
          "directProviderSdkDependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "kind": "observability-wiring-facts",
      "requiredTopLevel": ["package"],
      "skill_ref": "references/observability.md §4. OpenTelemetry 桥接",
      "agent_action": "Decide whether production top-level Layer wires the correct OTel SDK for this runtime.",
      "factsSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "hasEffectOpenTelemetryDependency",
          "hasEffectPlatformDependency",
          "opentelemetryImportedModules",
          "opentelemetryLayerFactories",
          "containsNodeSdkLayer",
          "containsWebSdkLayer",
          "containsOtlpLayer",
          "containsHttpClientToken",
          "containsFetchHttpClientLayer"
        ],
        "properties": {
          "hasEffectOpenTelemetryDependency": { "type": "boolean" },
          "hasEffectPlatformDependency": { "type": "boolean" },
          "opentelemetryImportedModules": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "opentelemetryLayerFactories": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "containsNodeSdkLayer": { "type": "boolean" },
          "containsWebSdkLayer": { "type": "boolean" },
          "containsOtlpLayer": { "type": "boolean" },
          "containsHttpClientToken": { "type": "boolean" },
          "containsFetchHttpClientLayer": { "type": "boolean" }
        }
      }
    },
    {
      "kind": "resilience-boundary-file",
      "requiredTopLevel": ["file"],
      "skill_ref": "references/scheduling.md §Jitter 与韧性边界",
      "agent_action": "Read the retry/repeat boundary and decide whether jitter belongs at this runtime pressure boundary.",
      "factsSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["calls", "scheduleMembers"],
        "properties": {
          "calls": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "scheduleMembers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "kind": "pubsub-ordering-file",
      "requiredTopLevel": ["file"],
      "skill_ref": "references/concurrency-primitives.md §PubSub 订阅时序",
      "agent_action": "Read the PubSub wiring and decide whether subscribers are established before first publish when replay is required.",
      "factsSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["calls", "pubsubConstructors"],
        "properties": {
          "calls": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "pubsubConstructors": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "kind": "effect-capability-proof-gap",
      "requiredTopLevel": ["package"],
      "skill_ref": "references/versions/v4.md §v4 OTel Peer Closure",
      "agent_action": "Treat this as a v4 beta proof gap: run the pinned v4 acceptance gate before promoting the peer closure to a deterministic finding.",
      "factsSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capability", "missingPeers", "declaredEffectVersions", "installedEffectVersions", "failureMode"],
        "properties": {
          "capability": { "const": "v4-otel-peer-closure" },
          "missingPeers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "declaredEffectVersions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "installedEffectVersions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "failureMode": { "const": "downgrade-to-signal-if-peer-closure-unproven" }
        }
      }
    }
  ]
}
