{
  "schemaVersion": 1,
  "defaults": {
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.mts",
      "**/*.cts"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/*.test.tsx",
      "**/*.spec.tsx",
      "**/*.d.ts"
    ]
  },
  "rules": [
    {
      "id": "EFF001",
      "name": "raw-try-catch",
      "severity": "error",
      "profiles": [
        "core"
      ],
      "forbid": "禁用原生 try/catch",
      "prefer": "改用 Effect.try / Effect.tryPromise 包裹副作用,失败通道用 Data.TaggedError",
      "references": [],
      "scanner": {
        "kind": "line-regex",
        "pattern": "\\btry\\s*\\{"
      }
    },
    {
      "id": "EFF002",
      "name": "async-function",
      "severity": "error",
      "profiles": [
        "core"
      ],
      "forbid": "禁用 async function",
      "prefer": "改写为 Effect.gen(function* () { ... }) + yield*",
      "references": [],
      "scanner": {
        "kind": "line-regex",
        "pattern": "\\basync\\s+function\\b"
      }
    },
    {
      "id": "EFF003",
      "name": "async-arrow",
      "severity": "error",
      "profiles": [
        "core"
      ],
      "forbid": "禁用 async 箭头函数",
      "prefer": "改写为 Effect.gen + yield*",
      "references": [],
      "scanner": {
        "kind": "line-regex",
        "pattern": "\\basync\\s*\\("
      }
    },
    {
      "id": "EFF004",
      "name": "await-keyword",
      "severity": "error",
      "profiles": [
        "core"
      ],
      "forbid": "禁用 await",
      "prefer": "Effect 内部用 yield*; 在边界用 Effect.runPromise / NodeRuntime.runMain",
      "references": [],
      "scanner": {
        "kind": "line-regex",
        "pattern": "\\bawait\\s+"
      }
    },
    {
      "id": "EFF005",
      "name": "promise-static",
      "severity": "error",
      "profiles": [
        "core"
      ],
      "forbid": "禁用 Promise 静态方法",
      "prefer": "改用 Effect.all({ concurrency }) / Effect.race / Effect.partition",
      "references": [],
      "scanner": {
        "kind": "line-regex",
        "pattern": "\\bPromise\\.(all|allSettled|race|any)\\b"
      }
    },
    {
      "id": "EFF006",
      "name": "import-axios",
      "severity": "error",
      "profiles": [
        "http-client",
        "http-server"
      ],
      "forbid": "禁用 axios",
      "prefer": "改用 @effect/platform/HttpClient,配合 Schema 化解码",
      "references": [],
      "scanner": {
        "kind": "line-regex",
        "pattern": "from\\s+['\"]axios['\"]"
      }
    },
