{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://effect-ecosystem-skill.local/gate-summary.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "ok", "exitCode", "summary", "effect", "tiers", "scanner", "complianceHash", "notProven", "artifacts"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "effect-mechanical-compliance-gate" },
    "ok": { "type": "boolean" },
    "exitCode": { "enum": [0, 1] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["findings", "errors", "warnings", "byRule"],
      "properties": {
        "findings": { "type": "number" },
        "errors": { "type": "number" },
        "warnings": { "type": "number" },
        "byRule": { "type": "object", "additionalProperties": { "type": "number" } }
      }
    },
    "effect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["versions", "resolution", "proof", "activeProfiles", "requiredReferences"],
      "properties": {
        "versions": { "type": "array", "items": { "type": "string" } },
        "resolution": { "type": ["string", "null"] },
        "proof": { "type": ["string", "null"] },
        "activeProfiles": { "type": "array", "items": { "type": "string" } },
        "requiredReferences": { "type": "array", "items": { "type": "string" } }
      }
    },
    "tiers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["block", "report", "review"],
      "properties": {
        "block": { "$ref": "#/$defs/findingList" },
        "report": { "$ref": "#/$defs/findingList" },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["signals"],
          "properties": {
            "signals": {
              "type": "object",
              "additionalProperties": false,
              "required": ["total", "byKind", "blocking", "packageRollups"],
              "properties": {
                "total": { "type": "number" },
                "byKind": { "type": "object", "additionalProperties": { "type": "number" } },
                "blocking": { "const": false },
                "packageRollups": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["kind", "package", "facts"],
                    "properties": {
                      "kind": { "const": "library-exported-effect-package" },
                      "package": { "type": "string" },
                      "facts": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["exportedEffectFiles", "withSpanFiles", "withoutSpanFiles"],
                        "properties": {
                          "exportedEffectFiles": { "type": "number" },
                          "withSpanFiles": { "type": "number" },
                          "withoutSpanFiles": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "scanner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["buildId", "gitCommit", "dirty", "inputHash", "fullHash", "comparePolicy"],
      "properties": {
        "buildId": { "type": ["string", "null"] },
        "gitCommit": { "type": ["string", "null"] },
        "dirty": { "type": ["boolean", "null"] },
        "inputHash": { "type": "string" },
        "fullHash": { "type": "string" },
        "comparePolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["compatibleWhen", "onScannerBuildIdChange"],
          "properties": {
            "compatibleWhen": { "const": "scannerBuildId equal" },
            "onScannerBuildIdChange": { "const": "re-baseline" }
          }
        }
      }
    },
    "complianceHash": { "type": "string" },
    "notProven": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source"],
        "allOf": [
          {
            "if": { "properties": { "source": { "const": "manifest" } }, "required": ["source"] },
            "then": { "required": ["owner", "reason"] }
          },
          {
            "if": { "properties": { "source": { "const": "scanner-default" } }, "required": ["source"] },
            "then": {
              "not": {
                "anyOf": [
                  { "required": ["owner"] },
                  { "required": ["reason"] }
                ]
              }
            }
          }
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "enum": ["scanner-default", "manifest"] },
          "owner": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "artifacts": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["rawJson", "evidence"],
          "properties": {
            "rawJson": { "const": "scan-result.json" },
            "evidence": { "const": "scan-evidence.json" }
          }
        }
      ]
    }
  },
  "$defs": {
    "findingList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ruleId", "severity", "file", "line", "message"],
        "properties": {
          "ruleId": { "pattern": "^EFF[0-9]{3}$" },
          "severity": { "enum": ["error", "warning"] },
          "file": { "type": "string" },
          "line": { "type": "number" },
          "message": { "type": "string" },
          "ref": { "type": "string" }
        }
      }
    }
  }
}
